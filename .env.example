# 对外只暴露 Web 网关；API 与 MCP 仅在 Compose 内部网络可见。
# 默认仅监听服务器回环地址，请使用 HTTPS 反向代理。明确了解风险后才改为 0.0.0.0。
SUBMAIL_BIND_ADDRESS=127.0.0.1
SUBMAIL_HTTP_PORT=8080

# 数据库模式：sqlite、mysql（Compose 内置 MySQL）、external_mysql（外部 MySQL）。
# 留空时 ./deploy.sh 会在交互终端询问，非交互环境默认 sqlite。
SUBMAIL_DB_MODE=
SUBMAIL_DB_DRIVER=sqlite
SUBMAIL_MYSQL_URL=
SUBMAIL_MYSQL_HOST=mysql
SUBMAIL_MYSQL_PORT=3306
SUBMAIL_MYSQL_DATABASE=submail
SUBMAIL_MYSQL_USER=submail
SUBMAIL_MYSQL_PASSWORD=
SUBMAIL_MYSQL_ROOT_PASSWORD=
SUBMAIL_MYSQL_SSL=false
SUBMAIL_MYSQL_CONNECTION_LIMIT=10

# Docker 部署固定使用 Compose Redis；这些值控制队列命名和并发。
SUBMAIL_QUEUE_PREFIX=submail
SUBMAIL_QUEUE_CONCURRENCY=4

# 留空并运行 ./deploy.sh 自动生成。不要使用示例值或提交 .env。
SUBMAIL_SECRET=

# 可选：填写后容器首次启动会自动创建管理员；留空则使用初始化接口。
SUBMAIL_ADMIN_NAME=管理员
SUBMAIL_ADMIN_EMAIL=
SUBMAIL_ADMIN_PASSWORD=

SUBMAIL_DEMO_MODE=false
SUBMAIL_MCP_MAX_BODY_BYTES=41943040
SUBMAIL_MCP_API_TIMEOUT_MS=120000
SUBMAIL_MAX_INCOMING_MESSAGE_BYTES=26214400
SUBMAIL_MAX_INCOMING_BODY_BYTES=2097152
SUBMAIL_MAX_OUTGOING_MESSAGE_BYTES=26214400
SUBMAIL_MAIL_CONNECTION_TIMEOUT_MS=30000
SUBMAIL_AUDIT_RETENTION_DAYS=30
SUBMAIL_SYNC_RUN_RETENTION_DAYS=90
